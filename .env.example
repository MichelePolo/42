# URL del Worker classifica (vedi worker/README.md). Copiare in .env.local.
# Se assente, classifica e mappa usano l'adapter demo locale.
VITE_LEADERBOARD_API=https://albero-42-api.TUO-ACCOUNT.workers.dev

# Site key (pubblica) di Cloudflare Turnstile. Va configurata insieme al
# secret sul Worker (wrangler secret put TURNSTILE_SECRET). Se assente,
# l'invio in classifica funziona senza captcha.
VITE_TURNSTILE_SITE_KEY=0xAAAA...
